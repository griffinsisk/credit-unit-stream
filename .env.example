CLOUDZERO_API_KEY=your_cloudzero_api_key_here          # Settings > API Keys — no Bearer prefix
CLOUDZERO_METRIC_NAME=your_metric_name_here            # Unit metric stream name (e.g. map-credit-estimates)
AWS_CREDITS_BUCKET=your-bucket-name-here               # Set by SAM; useful for local testing only
AWS_DEFAULT_REGION=us-east-1
